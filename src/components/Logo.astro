---
import fs from 'node:fs';
import path from 'node:path';

// The logo artwork lives in /public/skyrocket-logo.svg and is the single
// source of truth. We read it at BUILD TIME and inline it into the DOM so that
// the animation engine's CSS custom properties cascade into the SVG internals
// (.layer-estrella, #ignition-fx, .trail-reveal, .logo-base-layers,
// .logo-s-silhouette) and the JS querySelectors can reach them. An <img> tag
// would seal the SVG internals away from CSS vars and JS.
const logoSvg = fs.readFileSync(
  path.resolve('./public/skyrocket-logo.svg'),
  'utf8',
);
---

<div class="logo-container">
  <span class="logo-s">S</span>
  <Fragment set:html={logoSvg} />
</div>