---
import fs from 'node:fs';
import path from 'node:path';

// Three SVG layers for the logo animation, each inlined at build time from its
// own static file (currently empty placeholders).
//   logo-s.svg      → the S graphic (revealed after the text S undraws)
//   logo-trail.svg  → the trail path (drawn via stroke-dashoffset)
//   logo-spark.svg  → the star spark (animated along the S path)
const sSvg = fs.readFileSync(path.resolve('./public/logo-s.svg'), 'utf8');
const trailSvg = fs.readFileSync(path.resolve('./public/logo-trail.svg'), 'utf8');
const sparkSvg = fs.readFileSync(path.resolve('./public/logo-spark.svg'), 'utf8');
---

<div class="logo-container">
  <!-- Text S: drawn top→bottom on load, undraws when scroll triggers -->
  <!-- <span class="logo-s-text">S</span> -->
  <!-- SVG layers -->
  <div class="logo-s-graphic" set:html={sSvg}></div>
  <div class="trail-reveal" set:html={trailSvg}></div>
  <div class="layer-estrella" set:html={sparkSvg}></div>
  <span class="ignition-fx" id="ignition-fx" aria-hidden="true"></span>
</div>